<view class="container">

  <page-header title="人员管理" subtitle="管理排班人员与角色"></page-header>

  <!-- 人员列表 -->
  <view class="list-card">
    <view class="list-empty" wx:if="{{staffList.length === 0}}">
      <text class="empty-text">暂无人员，点击下方按钮添加</text>
    </view>

    <view
      class="staff-item"
      wx:for="{{staffList}}"
      wx:key="id"
    >
      <view class="item-left">
        <view class="color-dot" style="background: {{item.color}}"></view>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <view class="type-tag" style="background: {{item.color}}20; color: {{item.color}}">
            {{item.typeLabel}}
          </view>
        </view>
      </view>
      <view class="item-actions">
        <view class="action-btn edit-btn" bindtap="openEdit" data-id="{{item.id}}">编辑</view>
        <view class="action-btn delete-btn" bindtap="openDelete" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="openAdd">
    <text class="add-icon">＋</text>
    <text class="add-text">添加人员</text>
  </view>

  <view class="bottom-spacer"></view>

  <!-- 编辑/新增弹窗 -->
  <view class="modal-mask" hidden="{{!showModal}}" bindtap="closeModal">
    <view class="modal-panel" catchtap="noop">
      <view class="modal-title">{{isEdit ? '编辑人员' : '添加人员'}}</view>

      <!-- 姓名 -->
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input
          class="form-input"
          value="{{form.name}}"
          placeholder="请输入姓名"
          bindinput="onNameInput"
          maxlength="8"
        />
      </view>

      <!-- 类型 -->
      <view class="form-row">
        <text class="form-label">类型</text>
        <view class="type-options">
          <view
            class="type-chip {{form.type === item.value ? 'active' : ''}}"
            wx:for="{{typeOptions}}"
            wx:key="value"
            wx:for-item="item"
            bindtap="onTypeChange"
            data-type="{{item.value}}"
          >{{item.label}}</view>
        </view>
      </view>

      <!-- 颜色 -->
      <view class="form-row">
        <text class="form-label">颜色</text>
        <view class="color-grid">
          <view
            class="color-swatch {{form.color === color ? 'selected' : ''}}"
            wx:for="{{presetColors}}"
            wx:key="*this"
            wx:for-item="color"
            style="background: {{color}}"
            bindtap="onColorChange"
            data-color="{{color}}"
          >
            <view wx:if="{{form.color === color}}" class="swatch-check">✓</view>
          </view>
        </view>
      </view>

      <!-- 按钮 -->
      <view class="modal-btns">
        <view class="btn-cancel" bindtap="closeModal">取消</view>
        <view class="btn-confirm" bindtap="confirmSave">确认</view>
      </view>
    </view>
  </view>

  <!-- 删除确认弹窗 -->
  <view class="modal-mask" hidden="{{!showDeleteConfirm}}" bindtap="cancelDelete">
    <view class="modal-panel confirm-panel" catchtap="noop">
      <view class="modal-title">确认删除</view>
      <view class="confirm-text">确定要删除「{{deleteTargetName}}」吗？</view>
      <view class="confirm-hint">删除后排班缓存将自动重建</view>
      <view class="modal-btns">
        <view class="btn-cancel" bindtap="cancelDelete">取消</view>
        <view class="btn-confirm btn-danger" bindtap="confirmDelete">删除</view>
      </view>
    </view>
  </view>

</view>
