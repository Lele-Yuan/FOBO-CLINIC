.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
  padding-top: 280rpx;
}

/* 添加区域 */
.add-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.add-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.name-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.category-picker {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  background: #FEF0E7;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #FEB18F;
  white-space: nowrap;
  font-weight: 500;
}

.add-btn {
  width: 100% !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  background: #3F414E !important;
  color: #fff !important;
  border-radius: 14rpx !important;
  font-size: 28rpx !important;
  border: none !important;
  margin: 0 !important;
}

/* 菜品列表 */
.food-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.food-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.tag {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  white-space: nowrap;
  font-weight: 500;
}

.food-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 30rpx;
  border-radius: 50%;
  background: #F5F5F5;
}

.delete-btn:active {
  background: #FFE5E5;
  color: #ff7b3a;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
