<view class="container">
  <page-header
    title="我的菜单"
    subtitle="管理你的吃饭选项"
  ></page-header>

  <!-- 添加区域 -->
  <view class="add-section">
    <view class="add-row">
      <input
        class="name-input"
        placeholder="输入菜名"
        value="{{inputName}}"
        bindinput="onNameInput"
        confirm-type="done"
        bindconfirm="addFood"
      />
      <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="category-picker">{{categories[categoryIndex]}} ▾</view>
      </picker>
    </view>
    <button class="add-btn" bindtap="addFood">+ 添加</button>
  </view>

  <!-- 菜品列表 -->
  <view class="food-list" wx:if="{{foodList.length > 0}}">
    <view class="food-item" wx:for="{{foodList}}" wx:key="_id">
      <view class="tag" style="background: {{item.tagColor}}">{{item.category}}</view>
      <text class="food-name">{{item.name}}</text>
      <view class="delete-btn" bindtap="deleteFood" data-id="{{item._id}}" data-name="{{item.name}}">✕</view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{foodList.length === 0 && !loading}}">
    <text class="empty-icon">🍽️</text>
    <text class="empty-text">还没有菜品，快去添加吧</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
